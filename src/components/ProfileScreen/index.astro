---
import Screen from '../Screen/index.astro'
---

<Screen id="profile" title="Profile" description="自己紹介">
	<div class="container">
		<div class="avatar-row">
			<div class="avatar">
				<img src={'/static/anozon-icon.svg'} alt="anozon icon" />
			</div>
			<div class="avatar">
				<img src={'/static/anozon_cat.png'} alt="anozon cat icon" />
			</div>
			<div class="avatar">
				<img src={'/static/launcher-icon.svg'} alt="anozon logo" />
			</div>
		</div>
		<div class="name-badge">
			<h3>anozon</h3>
		</div>
		<div class="bio">
			<p>「あのぞん」です。</p>
			<p>ある2つのモノのインフラを作るために現れた。</p>
			<p>未来を想像するのが好き。</p>
		</div>
	</div>
</Screen>

<style>
	.container {
		text-align: center;
		padding: 8px 0;
	}

	.avatar-row {
		display: flex;
		justify-content: center;
		gap: 16px;
	}

	.avatar {
		width: 120px;
		height: 120px;
		border-radius: 50%;
		overflow: hidden;
		border: 3px solid #dcdcdc;
		transition: transform 0.3s ease, border-color 0.3s ease;
		&:hover {
			transform: scale(1.08);
			border-color: #333;
		}
		@media (max-width: 500px) {
			width: 90px;
			height: 90px;
		}
	}

	.avatar img {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.name-badge {
		margin-top: 16px;
	}

	.name-badge h3 {
		display: inline-block;
		font-size: 2rem;
		letter-spacing: 0.1em;
		padding: 4px 2em;
		background: #f5f5f5;
		border: 2px solid #e0e0e0;
		border-radius: 4px;
	}

	.bio {
		margin-top: 8px;
		line-height: 1.8;
	}

	.bio p {
		margin: 4px 0;
		color: #444;
	}
</style>
