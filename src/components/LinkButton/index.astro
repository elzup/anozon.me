---
import { Icon } from 'astro-icon/components'

const getIcon = (url: string): string => {
	if (url.search('github') >= 0) {
		return 'mdi:github'
	} else if (url.search('tumblr') >= 0) {
		return 'ri:tumblr-fill'
	} else {
		return 'ic:round-insert-link'
	}
}

const { href, text } = Astro.props
const iconId = getIcon(href)

export interface Props {
	href: string
	text?: string
}
---

<a href={href} aria-label={text || href} target="_blank" rel="noopener noreferrer" class="link-btn">
	<Icon name={iconId} />
	{text && <span class="label">{text}</span>}
</a>

<style>
	.link-btn {
		display: inline-flex;
		align-items: center;
		gap: 3px;
		padding: 2px 6px;
		color: #1a6dcc;
		font-size: 0.7rem;
		line-height: 1.3;
		white-space: nowrap;
		text-decoration: none;
		border-bottom: 1px solid #1a6dcc;
		transition: color 0.2s, border-color 0.2s;
		&:hover {
			color: #0d4a8b;
			border-color: #0d4a8b;
		}
	}

	[data-icon] {
		color: currentColor;
		width: 0.85em;
		height: 0.85em;
	}

	.label {
		color: currentColor;
	}
</style>
