---
import type { Product } from '../../types'
export interface Props {
	product: Product
}
const { product } = Astro.props
const size = product.size ?? 'M'
const hasImage = product.hasImage ?? false
---

<a
	href={product.url}
	target={'_blank'}
	data-disabled={!product.urlLive}
	data-size={size}
	rel="noopener noreferrer"
>
	<div class="card">
		<div class="img-wrap">
			{hasImage ? (
				<img src={`/static/${product.filename}`} alt={product.title} />
			) : (
				<div class="placeholder">
					<span>{product.title.slice(0, 2)}</span>
				</div>
			)}
		</div>
		<h4>{product.title}</h4>
		<p>{product.description}</p>
	</div>
</a>

<style>
	@keyframes hilight {
		0% {
			background: white;
		}
		100% {
			background: #eee;
		}
	}

	:root > a {
		position: relative;
		&:before {
			position: absolute;
			top: 0.5em;
			left: -0.5em;
			content: '⬢';
		}
		&:after {
			position: absolute;
			bottom: -0.5em;
			right: -0.5em;
			content: '⬢';
		}
		&[data-disabled='true'] {
			pointer-events: none;
			cursor: none;
		}
	}

	.card {
		width: 180px;
		text-align: center;
		background: #ffffffb0;
		margin-top: 12px;
		border: dashed #dcdcdc 1px;
		padding: 4px;
		&:hover {
			animation: hilight 0.5s ease 0s forwards;
		}
	}

	h4 {
		font-size: 0.8rem;
		margin: 4px 0 2px;
	}

	p {
		font-size: 0.7rem;
		margin: 0 0 4px;
		color: #666;
	}

	.img-wrap {
		height: 110px;
	}

	[data-size='S'] .card {
		width: 140px;
	}
	[data-size='S'] .img-wrap {
		height: 80px;
	}

	[data-size='L'] .card {
		width: 240px;
	}
	[data-size='L'] .img-wrap {
		height: 150px;
	}

	img {
		width: 95%;
		height: 95%;
		object-fit: contain;
		border-radius: 5px;
	}

	.placeholder {
		width: 100%;
		height: 100%;
		display: flex;
		align-items: center;
		justify-content: center;
		background: linear-gradient(135deg, #e0e0e0 0%, #c8c8c8 100%);
		border-radius: 5px;
	}
	.placeholder span {
		font-size: 1.8rem;
		color: #888;
		font-weight: bold;
	}
</style>
