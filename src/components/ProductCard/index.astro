---
import type { Product } from '../../types'
export interface Props {
	product: Product
}
const { product } = Astro.props
const size = product.size ?? 'M'
const hasImage = product.hasImage ?? false
---

<a
	href={product.url}
	target={'_blank'}
	data-disabled={!product.urlLive}
	data-size={size}
	rel="noopener noreferrer"
>
	<div class="card">
		<div class="img-wrap">
			{hasImage ? (
				<img src={`/static/${product.filename}`} alt={product.title} />
			) : (
				<div class="placeholder">
					<span>{product.title.slice(0, 2)}</span>
				</div>
			)}
		</div>
		<h4>{product.title}</h4>
		<p>{product.description}</p>
	</div>
</a>

<style>
	@keyframes hilight {
		0% {
			background: white;
		}
		100% {
			background: #eee;
		}
	}

	/* S=1col, M=2col, L=3col (grid column unit = 140px, gap = 8px) */
	:root > a {
		position: relative;
		grid-column: span 1;
		&:before {
			position: absolute;
			top: 0.5em;
			left: -0.3em;
			content: '⬢';
			font-size: 0.6rem;
		}
		&:after {
			position: absolute;
			bottom: -0.3em;
			right: -0.3em;
			content: '⬢';
			font-size: 0.6rem;
		}
		&[data-disabled='true'] {
			pointer-events: none;
			cursor: none;
		}
	}

	[data-size='M'] {
		grid-column: span 2;
	}
	[data-size='L'] {
		grid-column: span 3;
	}

	.card {
		width: 100%;
		text-align: center;
		background: #ffffffb0;
		border: solid #e0e0e0 1px;
		padding: 2px;
		box-sizing: border-box;
		&:hover {
			animation: hilight 0.5s ease 0s forwards;
		}
	}

	h4 {
		font-size: 0.7rem;
		margin: 2px 0 1px;
		line-height: 1.2;
	}

	p {
		font-size: 0.6rem;
		margin: 0 0 2px;
		color: #666;
		line-height: 1.2;
	}

	.img-wrap {
		height: 100px;
	}

	[data-size='M'] .img-wrap {
		height: 140px;
	}

	[data-size='L'] .img-wrap {
		height: 180px;
	}

	img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		border-radius: 2px;
	}

	.placeholder {
		width: 100%;
		height: 100%;
		display: flex;
		align-items: center;
		justify-content: center;
		background: linear-gradient(135deg, #e0e0e0 0%, #c8c8c8 100%);
		border-radius: 4px;
	}
	.placeholder span {
		font-size: 1.5rem;
		color: #888;
		font-weight: bold;
	}
</style>
