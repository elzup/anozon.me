---
export interface Props {
	id: string
	title: string
	description: string
	width?: number
}
const { id, title, description, width = 650 } = Astro.props
---

<section id={id} class="wrap" style={`--screen-w: ${width}px;`}>
	<div class="header">
		<h2>
			<span class="title">{title}</span>
			<span class="desc">{description}</span>
		</h2>
	</div>
	<slot />
</section>

<style>
	.wrap {
		margin: 5vh auto 0;
		padding: 10px;
		width: min(var(--screen-w, 650px), 94%);
	}

	.header {
		display: flex;
		justify-content: center;
	}

	h2 {
		text-align: center;
		border-bottom: solid 1px #ccc;
		padding-bottom: 8px;
		width: 100%;
		display: flex;
		align-items: baseline;
		justify-content: center;
		gap: 8px;
	}

	.title {
		font-size: 1.4rem;
		letter-spacing: 0.05em;
	}

	.desc {
		font-size: 0.9rem;
		color: #888;
		font-weight: normal;
	}
</style>
