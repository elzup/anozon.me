{
	"name": "anozon-me",
	"version": "2.0.0",
	"private": true,
	"homepage": "https://anozon.me/",
	"scripts": {
		"dev": "portless run --name anozon-me astro dev",
		"build": "astro build",
		"preview": "astro preview",
		"lint": "oxlint src --ignore-pattern '*.astro'",
		"sync:pull": "env -u NOTION_SECRET -u NOTION_TARGET_DB tsx --env-file=.env script/loadProducts.ts",
		"sync:push": "env -u NOTION_SECRET -u NOTION_TARGET_DB tsx --env-file=.env script/pushProducts.ts",
		"prepare": "husky"
	},
	"dependencies": {
		"@iconify-json/ic": "^1.2.0",
		"@iconify-json/ion": "^1.2.7",
		"@iconify-json/mdi": "^1.2.0",
		"@iconify-json/ri": "^1.2.0",
		"astro": "^5.0.0",
		"astro-icon": "^1.1.0"
	},
	"devDependencies": {
		"@notionhq/client": "2",
		"@types/node": "^22.0.0",
		"husky": "^9.0.0",
		"lint-staged": "^15.0.0",
		"oxlint": "^0.16.0",
		"postcss-preset-env": "^10.0.0",
		"tsx": "^4.21.0",
		"typescript": "^5.7.0"
	},
	"lint-staged": {
		"src/**/*.{ts,tsx}": [
			"oxlint --fix"
		]
	}
}
