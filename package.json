{
	"name": "anozon-me",
	"version": "2.0.0",
	"private": true,
	"homepage": "https://anozon.me/",
	"scripts": {
		"dev": "portless run --name anozon-me astro dev",
		"build": "astro build",
		"preview": "astro preview",
		"lint": "oxlint src --ignore-pattern '*.astro'",
		"sync:pull": "tsx --env-file=.env script/loadProducts.ts",
		"sync:push": "tsx --env-file=.env script/pushProducts.ts",
		"setenv": "node scripts/setup_env.js",
		"prepare": "husky"
	},
	"dependencies": {
		"@astrojs/react": "^4.2.0",
		"@iconify-json/ic": "^1.2.0",
		"@iconify-json/ion": "^1.2.7",
		"@iconify-json/mdi": "^1.2.0",
		"@iconify-json/ph": "^1.2.0",
		"@iconify-json/ri": "^1.2.0",
		"@types/react": "^18.3.0",
		"astro": "^5.0.0",
		"astro-icon": "^1.1.0",
		"react": "^18.3.0",
		"react-dom": "^18.3.0"
	},
	"devDependencies": {
		"@astrojs/partytown": "^2.1.0",
		"@notionhq/client": "^2.2.2",
		"@types/node": "^22.0.0",
		"@types/react-dom": "^18.3.0",
		"husky": "^9.0.0",
		"lint-staged": "^15.0.0",
		"open-props": "^1.7.0",
		"oxlint": "^0.16.0",
		"postcss-custom-media": "^11.0.0",
		"postcss-jit-props": "^1.0.14",
		"postcss-nesting": "^13.0.0",
		"postcss-preset-env": "^10.0.0",
		"tsx": "^4.21.0",
		"typescript": "^5.7.0"
	},
	"lint-staged": {
		"src/**/*.{ts,tsx}": [
			"oxlint --fix"
		]
	}
}
